:80 {
    # SSE and backend API
    handle /api/* {
        reverse_proxy backend:8000 {
            # SSE: disable response buffering + long timeouts
            transport http {
                read_timeout 24h
                write_timeout 24h
            }
            flush_interval -1
        }
    }
    # Frontend
    handle {
        reverse_proxy web:3000
    }
}
